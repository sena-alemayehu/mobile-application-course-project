<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="1" author="mohammed">
        <createSequence
                sequenceName="users_id_seq"
                startValue="1"
                incrementBy="50"
                minValue="1"
                cycle="false"/>
    </changeSet>

    <changeSet id="2" author="mohammed">
        <createTable tableName="users">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="public_id" type="UUID">
                <constraints nullable="false" unique="true" uniqueConstraintName="uc_users_public_id"/>
            </column>

            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="first_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="last_name" type="VARCHAR(255)"/>

            <column name="avatar_url" type="VARCHAR(255)"/>

            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uc_users_email"/>
            </column>

            <column name="role" type="VARCHAR(50)" defaultValue="USER">
                <constraints nullable="false"/>
            </column>

            <column name="email_verified" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

            <column name="locked" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="last_login_at" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="3" author="mohammed">
        <createIndex indexName="idx_users_email" tableName="users">
            <column name="email"/>
        </createIndex>
        <createIndex indexName="idx_users_public_id" tableName="users">
            <column name="public_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="4" author="mohammed">
        <addDefaultValue
                tableName="users"
                columnName="id"
                defaultValueSequenceNext="users_id_seq"/>
    </changeSet>

</databaseChangeLog>