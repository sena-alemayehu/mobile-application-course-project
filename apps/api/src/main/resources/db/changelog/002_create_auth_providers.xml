<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="6" author="mohammed">
        <createSequence
                sequenceName="auth_providers_id_seq"
                startValue="1"
                incrementBy="50"
                minValue="1"
                cycle="false"/>
    </changeSet>

    <changeSet id="7" author="mohammed">
        <createTable tableName="auth_providers">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_auth_providers_users"
                             references="users(id)"
                             deleteCascade="true"/>
            </column>
            <column name="provider_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="provider_user_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uc_auth_provider_user_id"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="8" author="mohammed">
        <addUniqueConstraint
                columnNames="user_id, provider_type"
                constraintName="uc_user_provider_type"
                tableName="auth_providers"/>
    </changeSet>

    <changeSet id="9" author="mohammed">
        <createIndex indexName="idx_provider_lookup"
                     tableName="auth_providers">
            <column name="provider_type"/>
            <column name="provider_user_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="10" author="mohammed">
        <addDefaultValue tableName="auth_providers"
                         columnName="id"
                         defaultValueSequenceNext="auth_providers_id_seq"/>
    </changeSet>

</databaseChangeLog>