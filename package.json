{
  "name": "workspace",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "gen:types": "pnpm --filter @workspace/types run gen",
    "build": "turbo build",
    "lint": "turbo lint",
    "spell": "cspell '**/*.{dart,ts,js,tsx,jsx,json,md,java,gradle,properties,yml,yaml}'",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@types/validator": "^13.15.10",
    "@typescript-eslint/parser": "^8.54.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "cspell": "^9.7.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.1",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  }
}
